<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_email_layout">
    <sys_email_layout action="INSERT_OR_UPDATE">
        <advanced>true</advanced>
        <advanced_layout><![CDATA[<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<style type="text/css">
    body {
        margin:0;
        padding:0;
        font-family: Arial, Helvetica, sans-serif;
        background-color:#F5F6F7;
    }
    table { border-collapse: collapse !important; }
    .sidebar { width:16px; }
    .content-card {
        background-color:#FFFFFF;
        border-radius:6px;
        padding:32px;
        color:#10171A;
        font-size:15px;
        line-height:22px;
    }
    .footer-text {
        font-size:12px;
        color:#555555;
        margin:0;
    }
    @media only screen and (min-width:600px) {
        .sidebar { width:32px; }
    }
</style>
</head>

<body>

<!-- OUTER WRAPPER -->
<table width="100%" cellpadding="0" cellspacing="0" align="center" style="background-color:#F5F6F7; padding:0; margin:0;">
  <tr>
    <td align="center">

      <!-- MAIN CONTAINER -->
      <table width="600" cellpadding="0" cellspacing="0" style="background-color:#FFFFFF; border-radius:6px;">

        <!-- HEADER / BANNER -->
        <tr>
          <td align="center" style="background-color:#FFD100; padding:20px;">
            <table cellpadding="0" cellspacing="0" width="100%" style="max-width:600px;">
              <tr>
                <td align="left" style="font-size:0;">
                  <!-- Logo -->
                  <img src="chromatech_email_banner.png" 
                       alt="ChromaTech" 
                       width="180" height="50" 
                       style="display:inline-block; vertical-align:middle;" />
                </td>
                <td align="right" style="font-size:16px; font-weight:bold; color:#000;">
                  Towards More Innovation
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- BODY / CONTENT CARD -->
        <tr>
          <td align="center">
            <table width="560" cellpadding="0" cellspacing="0" class="content-card">
              <tr>
                <td>
                  ${notification:body}
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td align="center" style="padding:15px 25px; background-color:#F5F6F7;">
            <p class="footer-text">
              © ${mail_script:ec_mail_current_year} ChromaTech Services
            </p>
            <p class="footer-text">
              This is an automated message from ChromaTech Services. Please do not reply.
            </p>
            <br/>
            ${NOTIF_UNSUB} | ${NOTIF_PREFS}
          </td>
        </tr>

      </table>

    </td>
  </tr>
</table>

</body>
</html>
]]></advanced_layout>
        <description>Notification Layout for ChromaTech Services</description>
