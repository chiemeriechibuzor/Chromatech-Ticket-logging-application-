        <value>(function(outputs, steps, stepResult, assertEqual) {&#13;
    var tableName = 'x_1839224_chroma_0_chromatech_customer_queries'; // Replace with your table&#13;
    var fieldName = 'first_reported_on';       // Replace with your field&#13;
&#13;
    var gr = new GlideRecord('sys_dictionary');&#13;
    // Check both your table and the parent 'task' table for inherited fields&#13;
    var qc = gr.addQuery('name', tableName);&#13;
    qc.addOrCondition('name', 'task'); &#13;
    gr.addQuery('element', fieldName);&#13;
    gr.query();&#13;
&#13;
    if (gr.next()) {&#13;
        // The internal name for "Date/Time" is 'glide_date_time'&#13;
        var actualType = gr.getValue('internal_type');&#13;
        &#13;
        if (actualType === 'glide_date_time') {&#13;
            stepResult.setOutputMessage("Success: Field '" + fieldName + "' is a Date/Time type.");&#13;
            return true;&#13;
        } else {&#13;
            // Provide clarity if it's a 'glide_date' (Date only) instead&#13;
            stepResult.setOutputMessage("Failure: Expected 'glide_date_time', but found '" + actualType + "'.");&#13;
            return false;&#13;
        }&#13;
    } else {&#13;
        stepResult.setOutputMessage("Failure: Could not find dictionary entry for field: " + fieldName);&#13;
        return false;&#13;
    }&#13;
})(outputs, steps, stepResult, assertEqual);</value>
