        <value>(function(outputs, steps, stepResult, assertEqual) {&#13;
    var expected = ["Chroma Admin", "Chroma ITIL", "Chroma Developers", "ChromaTech Helpdesk", "ChromaTech Services"];&#13;
    var expectedString = expected.sort().join(',');&#13;
    &#13;
    var actualGroups = [];&#13;
    var gr = new GlideRecord('sys_user_group');&#13;
    // Ensure this matches the exact filter on your Assignment Group field&#13;
    gr.addActiveQuery(); &#13;
    gr.addQuery('name', 'STARTSWITH', 'Chroma'); &#13;
    gr.query();&#13;
    &#13;
    while (gr.next()) {&#13;
        actualGroups.push(gr.getValue('name').toString());&#13;
    }&#13;
    &#13;
    var actualString = actualGroups.sort().join(',');&#13;
&#13;
    if (actualString === expectedString) {&#13;
        stepResult.setOutputMessage("Success: Only the allowed groups found.");&#13;
        return true; &#13;
    } else {&#13;
        // This will print the actual list of groups found to the ATF failure log&#13;
        var msg = "FAIL: Group mismatch. \nExpected: " + expectedString + "\nFound: " + actualString;&#13;
        gs.error(msg); // Forces a log entry in System Logs&#13;
        stepResult.setOutputMessage(msg);&#13;
        stepResult.setFailed(msg);&#13;
        return false;&#13;
    }&#13;
})(outputs, steps, stepResult, assertEqual);&#13;
</value>
