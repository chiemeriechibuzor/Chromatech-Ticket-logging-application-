        <script><![CDATA[(function executeRule(current, previous /*null when insert*/) {

    // Ensure requester is present
    if (!current.requester) {
        return;
    }

    // GlideAggregate is more efficient than GlideRecord for counts
    var ga = new GlideAggregate('x_chromatech_customer_queries');
    ga.addQuery('requester', current.requester);
    ga.addAggregate('COUNT');
    ga.query();

    var queryCount = 0;

    if (ga.next()) {
        queryCount = parseInt(ga.getAggregate('COUNT'), 10);
    }

    // If requester already has 7 or more queries, block creation
    if (queryCount >= 7) {
        gs.addErrorMessage(
            'Already 7 queries are present for this requester. ' +
            'Please delete any previous query then try to create a new one for this requester.'
        );

        current.setAbortAction(true);
    }

})(current, previous);
]]></script>
